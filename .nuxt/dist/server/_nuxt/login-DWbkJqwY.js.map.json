{"file":"login-DWbkJqwY.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AAmBc,aAAA;AACd,UAAM,QAAQ,IAAI,EAAE;AAAG,UAAM,WAAW,IAAI,EAAE;AAAG,UAAM,UAAU,IAAI,KAAK;AAAG,UAAM,WAAW,IAAI,EAAE;AACpF,eAAA;AAAkC,iBAAA;AAA8B,aAAA;;;mBApBzEA,eAAAC,WAAA,EAAA,OAAM,qDAAA,GAAoD,MAAA,CAAA,yRAOFC,MAAA,KAAA,CAAK,sHACFA,MAAA,QAAA,CAAQ,wHACNA,MAAA,OAAA,CAAO,IAAA,cAAA,qBAAKA,MAAA,OAAA,IAAO,kBAAA,SAAA;UACtEA,MAAA,QAAA,GAAQ;4EAA8CA,MAAA,QAAA,CAAQ,CAAA,MAAA;AAAA;;;;;QACO,IAAG;AAAA,QAAY,OAAM;AAAA,MAAA;yBAA/B,CAAwF,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAAnB,UAAQ;AAAA,YAAA;AAAA;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_push","_parent"],"sources":["../../../../pages/login.vue"],"sourcesContent":["<template>\n  <div class=\"min-h-[70vh] flex items-center justify-center px-4\">\n    <div class=\"w-full max-w-md\">\n      <div class=\"text-center mb-8\">\n        <h1 class=\"text-2xl font-bold text-gray-900\">Welcome back</h1>\n        <p class=\"text-gray-500 mt-1\">Sign in to your account</p>\n      </div>\n      <form @submit.prevent=\"handleLogin\" class=\"space-y-4\">\n        <div><label class=\"label\">Email</label><input v-model=\"email\" type=\"email\" class=\"input\" required /></div>\n        <div><label class=\"label\">Password</label><input v-model=\"password\" type=\"password\" class=\"input\" required /></div>\n        <button type=\"submit\" class=\"btn-primary w-full\" :disabled=\"loading\">{{ loading ? 'Signing in...' : 'Sign in' }}</button>\n        <p v-if=\"errorMsg\" class=\"text-red-500 text-sm text-center\">{{ errorMsg }}</p>\n        <p class=\"text-center text-sm text-gray-500\">Don't have an account? <NuxtLink to=\"/register\" class=\"text-gray-900 font-medium underline\">Register</NuxtLink></p>\n      </form>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst route = useRoute()\nconst email = ref(''); const password = ref(''); const loading = ref(false); const errorMsg = ref('')\nconst authApi = useAuthApi(); const { setAuth } = useAuthState(); const toast = useToast()\n\nasync function handleLogin() {\n  loading.value = true; errorMsg.value = ''\n  try {\n    const r = await authApi.login(email.value, password.value)\n    if (r?.data) { setAuth(r.data.user, r.data.tokens); toast.success('Welcome back!'); navigateTo((route.query.redirect as string) || '/') }\n  } catch (e: any) { errorMsg.value = e?.data?.message || 'Invalid credentials' }\n  finally { loading.value = false }\n}\n</script>\n"],"version":3}