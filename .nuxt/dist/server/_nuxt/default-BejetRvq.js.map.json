 for Badge */\n.pop-enter-active {\n  animation: pop-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n}\n@keyframes pop-in {\n  0% { transform: scale(0); opacity: 0; }\n  100% { transform: scale(1); opacity: 1; }\n}\n</style>\n"],"version":3}