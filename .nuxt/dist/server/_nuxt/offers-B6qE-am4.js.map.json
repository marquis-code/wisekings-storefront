,UAAU,QAAQ,OAAO,QAAM;8CAC5C,OAAK,QAAQ,OAAM,CAAA,CAAA,kBACnB,OAAK,QAAQ,IAAI;;;;oBAIZ,MAAK;AAAA,oBAAiB,MAAK;AAAA,oBAAK,OAAM;AAAA,kBAAA;;;AAGnC,oBAAA,QAAQ,gBAAc;uKAC5B,KAAK,OAAK,IAAM,QAAQ,QAAQ,QAAQ,kBAAc,GAAA,CAAA;;;;oLAI+CJ,eAAA,QAAQ,IAAI,4IAE7D,QAAQ,MAAM,QAAO,CAAA,CAAA;AAChE,oBAAA,QAAQ,gBAAc;wGAAiD,QAAQ,eAAe,QAAO,CAAA,CAAA;;;;;;;kBAnBrHK,YAcM,OAAA,EAdD,OAAM,mKAA+J;AAAA,oBAEhK,QAAQ,UAAU,QAAQ,OAAO,uBADzCC,YAKC,OAAA;AAAA;sBAHE,KAAK,QAAQ,OAAM,CAAA;AAAA,sBACnB,KAAK,QAAQ;AAAA,sBACd,OAAM;AAAA,oBAAA,6CAERA,YAEM,OAAA;AAAA;sBAFM,OAAM;AAAA,oBAAA;sBAChBD,YAA8D,iBAAA;AAAA,wBAAxD,MAAK;AAAA,wBAAiB,MAAK;AAAA,wBAAK,OAAM;AAAA,sBAAA;;oBAGnC,QAAQ,+BAAnBC,YAEM,OAAA;AAAA;sBAF6B,OAAM;AAAA,oBAAA,mBACpC,KAAK,OAAK,IAAM,QAAQ,QAAQ,QAAQ,kBAAc,GAAA,CAAA,IAAW,UACtE,CAAA;;kBAEFD,YAMM,OAAA,EAND,OAAM,eAAW;AAAA,oBACpBA,YAA8H,QAA1H,OAAM,6FAAA,GAA4FE,gBAAI,QAAQ,IAAI,GAAA,CAAA;AAAA,oBACtHF,YAGM,OAAA,EAHD,OAAM,kCAA8B;AAAA,sBACvCA,YAAyF,QAAA,EAAnF,OAAM,0CAAuC,MAACE,gBAAG,QAAQ,MAAM,QAAO,CAAA,CAAA,GAAA,CAAA;AAAA,sBAChE,QAAQ,+BAApBD,YAA8H,QAAA;AAAA;wBAA1F,OAAM;AAAA,sBAAA,GAAqC,MAACC,gBAAG,QAAQ,eAAe,QAAO,CAAA,CAAA,GAAA,CAAA;;;;;;;;;;;;;UAQ/G,MAAK;AAAA,UAAa,MAAK;AAAA,UAAK,OAAM;AAAA,QAAA;;;UAIhC,IAAG;AAAA,UAAY,OAAM;AAAA,QAAA;2BAA/B,CAGW,GAAAJ,QAAAC,UAAA,aAAA;;;;gBADH,MAAK;AAAA,gBAAqB,MAAK;AAAA,cAAA;;;gCAFiJ,qBAEtL;AAAA,gBAAAC,YAA4C,iBAAA;AAAA,kBAAtC,MAAK;AAAA,kBAAqB,MAAK;AAAA,gBAAA;;;;;;;;;;;;;;;;;;","names":["_ssrRenderList","_ssrInterpolate","_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_createBlock","_toDisplayString"],"sources":["../../../../components/core/Dropdown.vue","../../../../pages/offers.vue"],"sourcesContent":["<template>\n  <div class=\"relative\" ref=\"dropdownRef\">\n    <div @click=\"toggleOpen\" class=\"cursor-pointer\">\n      <slot name=\"trigger\" :isOpen=\"isOpen\" :selected=\"selected\">\n        <div :class=\"[\n          'flex items-center justify-between px-4 py-3.5 rounded-2xl border transition-all font-medium text-sm',\n          isOpen \n            ? 'border-[#033958] ring-2 ring-[#033958]/10 bg-white' \n            : 'border-gray-200 bg-gray-50 hover:border-gray-300'\n        ]\">\n          <span :class=\"selected ? 'text-gray-900' : 'text-gray-400'\">\n            {{ selected ? selectedLabel : placeholder }}\n          </span>\n          <Icon \n            name=\"lucide:chevron-down\" \n            size=\"18\" \n            :class=\"['text-gray-400 transition-transform duration-200', isOpen ? 'rotate-180' : '']\" \n          />\n        </div>\n      </slot>\n    </div>\n\n    <Transition\n      enter-active-class=\"transition duration-200 ease-out\"\n      enter-from-class=\"opacity-0 scale-95 -translate-y-2\"\n      enter-to-class=\"opacity-100 scale-100 translate-y-0\"\n      leave-active-class=\"transition duration-150 ease-in\"\n      leave-from-class=\"opacity-100 scale-100 translate-y-0\"\n      leave-to-class=\"opacity-0 scale-95 -translate-y-2\"\n    >\n      <div \n        v-if=\"isOpen\" \n        class=\"absolute z-50 mt-2 w-full bg-white border border-gray-100 rounded-2xl shadow-xl shadow-black/5 py-2 max-h-60 overflow-y-auto\"\n      >\n        <div\n          v-for=\"option in options\"\n          :key=\"option.value\"\n          @click=\"selectOption(option)\"\n          :class=\"[\n            'flex items-center gap-3 px-4 py-3 cursor-pointer transition-all text-sm font-medium',\n            selected === option.value \n              ? 'bg-[#033958]/5 text-[#033958]' \n              : 'text-gray-700 hover:bg-gray-50'\n          ]\"\n        >\n          <Icon v-if=\"option.icon\" :name=\"option.icon\" size=\"18\" class=\"flex-shrink-0\" />\n          <span>{{ option.label }}</span>\n          <Icon \n            v-if=\"selected === option.value\" \n            name=\"lucide:check\" \n            size=\"16\" \n            class=\"ml-auto text-[#033958]\" \n          />\n        </div>\n      </div>\n    </Transition>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, computed, onMounted, onBeforeUnmount } from 'vue'\n\ninterface DropdownOption {\n  value: string\n  label: string\n  icon?: string\n}\n\nconst props = defineProps<{\n  options: DropdownOption[]\n  modelValue?: string\n  placeholder?: string\n}>()\n\nconst emit = defineEmits(['update:modelValue'])\n\nconst isOpen = ref(false)\nconst dropdownRef = ref<HTMLElement | null>(null)\n\nconst selected = computed(() => props.modelValue)\nconst selectedLabel = computed(() => {\n  const opt = props.options.find(o => o.value === props.modelValue)\n  return opt?.label || ''\n})\n\nfunction toggleOpen() { isOpen.value = !isOpen.value }\n\nfunction selectOption(option: DropdownOption) {\n  emit('update:modelValue', option.value)\n  isOpen.value = false\n}\n\nfunction handleClickOutside(e: MouseEvent) {\n  if (dropdownRef.value && !dropdownRef.value.contains(e.target as Node)) {\n    isOpen.value = false\n  }\n}\n\nonMounted(() => document.addEventListener('click', handleClickOutside))\nonBeforeUnmount(() => document.removeEventListener('click', handleClickOutside))\n</script>\n","<template>\n  <div class=\"min-h-screen bg-white\">\n    <section class=\"relative h-[45vh] min-h-[400px] flex items-center overflow-hidden bg-orange-600\">\n      <div class=\"absolute inset-0 z-0\">\n        <img \n          src=\"https://images.unsplash.com/photo-1606787366850-de6330128bfc?q=80&w=2000&auto=format&fit=crop\" \n          class=\"w-full h-full object-cover opacity-40 animate-ken-burns\" \n        />\n        <div class=\"absolute inset-0 bg-gradient-to-t from-orange-700 via-orange-600/40 to-transparent\"></div>\n      </div>\n      <div class=\"max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 w-full relative z-10 pt-20 text-center\">\n        <div class=\"inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm text-white px-4 py-2 rounded-full text-[10px] font-black tracking-widest uppercase mb-6 mx-auto\">\n          <Icon name=\"lucide:flame\" size=\"14\" class=\"text-amber-400\" />\n          Limited Time Deals\n        </div>\n        <h1 class=\"text-4xl md:text-6xl font-black text-white tracking-tighter leading-none mb-4\">Special Offers & Deals</h1>\n        <p class=\"text-lg text-white/80 max-w-2xl mx-auto font-medium\">Save big on your favourite snacks. Freshly baked deals updated weekly.</p>\n      </div>\n    </section>\n\n    <!-- Deals Section -->\n    <section class=\"max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-16\">\n      <div class=\"flex items-center justify-between mb-10\">\n        <h2 class=\"text-2xl font-extrabold text-gray-900\">Today's Deals</h2>\n        <CoreDropdown \n          v-model=\"sortBy\" \n          :options=\"sortOptions\" \n          placeholder=\"Sort by\" \n        />\n      </div>\n\n      <div v-if=\"loading\" class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6\">\n        <div v-for=\"i in 8\" :key=\"i\" class=\"animate-pulse\">\n          <div class=\"bg-gray-100 rounded-3xl h-56\"></div>\n          <div class=\"mt-4 h-5 bg-gray-100 rounded w-3/4\"></div>\n          <div class=\"mt-2 h-4 bg-gray-50 rounded w-1/2\"></div>\n        </div>\n      </div>\n\n      <div v-else-if=\"offers.length\" class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6\">\n        <NuxtLink \n          v-for=\"product in offers\" \n          :key=\"product._id\" \n          :to=\"`/products/${product.slug}`\"\n          class=\"group\"\n        >\n          <div class=\"relative rounded-3xl overflow-hidden h-56 bg-gray-50 border border-gray-100 group-hover:shadow-xl group-hover:shadow-orange-500/5 transition-all duration-300\">\n            <img \n              v-if=\"product.images && product.images.length\" \n              :src=\"product.images[0]\" \n              :alt=\"product.name\"\n              class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\"\n            >\n            <div v-else class=\"flex items-center justify-center h-full\">\n              <Icon name=\"lucide:package\" size=\"36\" class=\"text-gray-300\" />\n            </div>\n            <!-- Deal Badge -->\n            <div v-if=\"product.compareAtPrice\" class=\"absolute top-4 left-4 bg-red-500 text-white px-3 py-1 rounded-full text-xs font-extrabold shadow-lg\">\n              {{ Math.round((1 - product.price / product.compareAtPrice) * 100) }}% OFF\n            </div>\n          </div>\n          <div class=\"mt-5 px-1\">\n            <h3 class=\"text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-1\">{{ product.name }}</h3>\n            <div class=\"flex items-center gap-2 mt-2\">\n              <span class=\"text-lg font-extrabold text-gray-900\">${{ product.price.toFixed(2) }}</span>\n              <span v-if=\"product.compareAtPrice\" class=\"text-sm text-gray-400 line-through\">${{ product.compareAtPrice.toFixed(2) }}</span>\n            </div>\n          </div>\n        </NuxtLink>\n      </div>\n\n      <div v-else class=\"text-center py-20\">\n        <div class=\"w-24 h-24 bg-amber-50 rounded-3xl flex items-center justify-center mx-auto mb-6\">\n          <Icon name=\"lucide:tag\" size=\"40\" class=\"text-amber-400\" />\n        </div>\n        <h3 class=\"text-xl font-bold text-gray-900 mb-2\">No offers at the moment</h3>\n        <p class=\"text-gray-500 mb-6\">Check back soon for deals and promotions!</p>\n        <NuxtLink to=\"/products\" class=\"inline-flex items-center gap-2 bg-[#033958] text-white px-8 py-3 rounded-2xl font-bold hover:bg-[#022a45] transition-all shadow-lg shadow-[#033958]/10\">\n          Browse All Snacks\n          <Icon name=\"lucide:arrow-right\" size=\"18\" />\n        </NuxtLink>\n      </div>\n    </section>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, onMounted, computed } from 'vue'\nimport { products_api } from '@/api_factory/modules/products'\n\nconst allProducts = ref<any[]>([])\nconst loading = ref(true)\nconst sortBy = ref('discount')\n\nconst sortOptions = [\n  { value: 'discount', label: 'Biggest Discount' },\n  { value: 'price-asc', label: 'Price: Low to High' },\n  { value: 'price-desc', label: 'Price: High to Low' },\n  { value: 'name', label: 'Name: A-Z' },\n]\n\n// Filter products that have a compareAtPrice (i.e. on offer)\nconst offers = computed(() => {\n  let items = allProducts.value.filter(p => p.compareAtPrice && p.compareAtPrice > p.price)\n  \n  switch (sortBy.value) {\n    case 'discount':\n      items.sort((a, b) => (1 - b.price / b.compareAtPrice) - (1 - a.price / a.compareAtPrice))\n      break\n    case 'price-asc':\n      items.sort((a, b) => a.price - b.price)\n      break\n    case 'price-desc':\n      items.sort((a, b) => b.price - a.price)\n      break\n    case 'name':\n      items.sort((a, b) => a.name.localeCompare(b.name))\n      break\n  }\n  return items\n})\n\nonMounted(async () => {\n  try {\n    const res = await products_api.get()\n    allProducts.value = res?.data?.data || res?.data || []\n  } catch (e) {\n    console.error('Error fetching offers:', e)\n  } finally {\n    loading.value = false\n  }\n})\n</script>\n\n<style>\n@keyframes ken-burns {\n  0% { transform: scale(1) translate(0); }\n  50% { transform: scale(1.1) translate(-1%, -1%); }\n  100% { transform: scale(1.2) translate(-2%, -2%); }\n}\n.animate-ken-burns {\n  animation: ken-burns 30s ease-in-out infinite alternate;\n}\n</style>\n"],"version":3}